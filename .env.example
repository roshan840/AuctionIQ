# Gemini API Configuration
# Get your keys from: https://aistudio.google.com/app/apikey
# Multiple keys can be comma-separated for fallback
GEMINI_API_KEYS=YOUR_API_KEY_1,YOUR_API_KEY_2
GEMINI_MODEL_NAME=gemini-2.0-flash

# Optional: paste cookie string from browser after Cloudflare verification
# Example: cf_clearance=...; __cf_bm=...
EAUCTIONS_COOKIE=

# Optional: browser user agent used by scraper
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36

# Application Settings
DEBUG=False
PORT=8501
